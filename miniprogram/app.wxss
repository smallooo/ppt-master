/* ===== Global design tokens ===== */
page {
  background: #f4f6fb;
  color: #0f172a;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  --primary: #2563eb;
  --primary-soft: #dbeafe;
  --primary-grad: linear-gradient(135deg, #4f46e5 0%, #2563eb 60%, #06b6d4 100%);
  --text: #0f172a;
  --muted: #64748b;
  --border: #e2e8f0;
  --danger: #dc2626;
  --warn: #d97706;
  --ok: #059669;
}

view, text, button, input, picker { box-sizing: border-box; }

.container {
  padding: 24rpx 24rpx calc(160rpx + env(safe-area-inset-bottom));
}
.container-tight {
  padding: 24rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
}

/* ===== Hero header (gradient) ===== */
.hero {
  background: var(--primary-grad);
  color: #ffffff;
  border-radius: 28rpx;
  padding: 40rpx 32rpx 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 16rpx 40rpx rgba(37, 99, 235, 0.25);
}
.hero-title { font-size: 40rpx; font-weight: 700; letter-spacing: 1rpx; }
.hero-sub { font-size: 24rpx; opacity: 0.85; margin-top: 8rpx; }

/* ===== Card ===== */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 18rpx rgba(15, 23, 42, 0.04);
  border: 2rpx solid rgba(226, 232, 240, 0.6);
}
.card-tight { padding: 20rpx 24rpx; }

.title { font-size: 34rpx; font-weight: 600; color: var(--text); }
.section-title { font-size: 28rpx; font-weight: 600; color: var(--text); display: flex; align-items: center; }
.section-title::before {
  content: ""; width: 6rpx; height: 28rpx; background: var(--primary);
  border-radius: 4rpx; margin-right: 14rpx;
}
.subtitle { color: var(--muted); font-size: 24rpx; line-height: 1.5; }
.divider { height: 1rpx; background: var(--border); margin: 20rpx 0; }

/* ===== Buttons ===== */
.btn {
  background: var(--primary-grad);
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 500;
  padding: 22rpx 0;
  text-align: center;
  margin-top: 18rpx;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.25);
  transition: opacity 0.15s;
}
.btn:active { opacity: 0.85; }
.btn[disabled] { background: #cbd5e1; box-shadow: none; color: #ffffff; }

.btn-secondary {
  background: var(--primary-soft);
  color: var(--primary);
  border-radius: 999rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  text-align: center;
  margin-top: 12rpx;
}
.btn-secondary:active { opacity: 0.85; }

.btn-danger {
  background: #ffffff;
  color: var(--danger);
  border: 2rpx solid #fecaca;
  border-radius: 999rpx;
  font-size: 28rpx;
  padding: 18rpx 0;
  text-align: center;
  margin-top: 12rpx;
}

.btn-ghost {
  background: transparent;
  color: var(--muted);
  font-size: 24rpx;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  border: 2rpx solid var(--border);
  display: inline-block;
}

/* ===== Badges ===== */
.badge {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  color: #334155;
  font-size: 22rpx;
  font-weight: 500;
}
.badge-warn { background: #fef3c7; color: #92400e; }
.badge-ok   { background: #dcfce7; color: #166534; }
.badge-err  { background: #fee2e2; color: #991b1b; }
.badge-info { background: var(--primary-soft); color: var(--primary); }

/* ===== Layout helpers ===== */
.row { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.row-start { display: flex; align-items: flex-start; gap: 16rpx; }
.col { display: flex; flex-direction: column; gap: 12rpx; }
.flex-1 { flex: 1; min-width: 0; }
.text-ellipsis {
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}

/* ===== Forms ===== */
.input {
  background: #f1f5f9;
  border-radius: 14rpx;
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  margin-top: 12rpx;
  border: 2rpx solid transparent;
}

.label {
  color: var(--muted);
  font-size: 24rpx;
  margin-top: 20rpx;
  margin-bottom: 4rpx;
}

/* ===== Empty / loading ===== */
.empty {
  text-align: center;
  color: #94a3b8;
  padding: 100rpx 0 60rpx;
  font-size: 26rpx;
}
.empty-emoji { font-size: 80rpx; display: block; margin-bottom: 12rpx; }

/* ===== Progress ===== */
.progress-track {
  height: 14rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  overflow: hidden;
}
.progress-bar {
  height: 100%;
  background: var(--primary-grad);
  border-radius: 999rpx;
  transition: width 0.4s ease;
}
.progress-pulse {
  background: var(--primary-grad);
  background-size: 200% 100%;
  animation: pulse-bg 1.6s linear infinite;
}
@keyframes pulse-bg {
  0% { background-position: 200% 0; }
  100% { background-position: 0 0; }
}

/* ===== Stepper (4-step) ===== */
.stepper { display: flex; align-items: center; margin: 20rpx 0 4rpx; }
.stepper-dot {
  width: 36rpx; height: 36rpx; border-radius: 50%;
  background: #e2e8f0; color: #94a3b8;
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; font-weight: 600;
}
.stepper-dot.active { background: var(--primary); color: #ffffff; }
.stepper-dot.done { background: var(--ok); color: #ffffff; }
.stepper-bar {
  flex: 1; height: 4rpx; background: #e2e8f0; margin: 0 6rpx;
}
.stepper-bar.done { background: var(--ok); }
.stepper-bar.active { background: var(--primary); }

/* ===== List item rows ===== */
.list-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.list-item:last-child { border-bottom: none; }
.list-icon {
  width: 64rpx; height: 64rpx; border-radius: 16rpx;
  background: var(--primary-soft); color: var(--primary);
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; margin-right: 20rpx; flex-shrink: 0;
}

/* ===== Floating action button ===== */
.fab {
  position: fixed; right: 36rpx; bottom: 140rpx;
  width: 110rpx; height: 110rpx; border-radius: 50%;
  background: var(--primary-grad);
  color: #ffffff;
  font-size: 60rpx; font-weight: 300; line-height: 110rpx;
  text-align: center;
  box-shadow: 0 12rpx 32rpx rgba(37, 99, 235, 0.4);
  z-index: 50;
}
.fab:active { transform: scale(0.94); }

/* ===== Sticky bottom action bar ===== */
.action-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: rgba(255,255,255,0.96);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--border);
  display: flex; gap: 16rpx;
  z-index: 40;
}
.action-bar .btn, .action-bar .btn-secondary, .action-bar .btn-danger {
  margin-top: 0; flex: 1; padding: 22rpx 0;
}

/* ===== Avatar ===== */
.avatar {
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex; align-items: center; justify-content: center;
  font-size: 48rpx; color: #ffffff; overflow: hidden;
  border: 2rpx solid rgba(255,255,255,0.4);
}
.avatar image { width: 100%; height: 100%; }

/* ===== Tab pill bar ===== */
.tab-pill {
  display: flex;
  background: #ffffff;
  border-radius: 999rpx;
  padding: 6rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 18rpx rgba(15, 23, 42, 0.04);
}
.tab-pill-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: var(--muted);
  border-radius: 999rpx;
}
.tab-pill-item.active {
  background: var(--primary-grad);
  color: #ffffff;
  font-weight: 500;
}

/* ===== Timeline (job events) ===== */
.timeline { padding-left: 32rpx; position: relative; }
.timeline::before {
  content: ""; position: absolute; left: 12rpx; top: 8rpx; bottom: 8rpx;
  width: 2rpx; background: var(--border);
}
.timeline-item { position: relative; padding: 12rpx 0; }
.timeline-item::before {
  content: ""; position: absolute; left: -28rpx; top: 22rpx;
  width: 16rpx; height: 16rpx; border-radius: 50%;
  background: var(--primary); border: 4rpx solid #ffffff;
  box-shadow: 0 0 0 2rpx var(--primary-soft);
}
.timeline-meta { font-size: 22rpx; color: var(--muted); }
.timeline-text { font-size: 26rpx; color: var(--text); margin-top: 4rpx; }

/* ===== Drop zone ===== */
.dropzone {
  border: 2rpx dashed #94a3b8;
  border-radius: 20rpx;
  padding: 40rpx 24rpx;
  text-align: center;
  color: var(--muted);
  background: #f8fafc;
  margin-top: 16rpx;
}
.dropzone-emoji { font-size: 56rpx; display: block; margin-bottom: 8rpx; }

/* ===== Code block (suggested_spec preview) ===== */
.code-block {
  background: #0f172a;
  color: #e2e8f0;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 22rpx;
  font-family: "SF Mono", Menlo, Consolas, monospace;
  white-space: pre-wrap;
  word-break: break-all;
  max-height: 360rpx;
  overflow: auto;
  margin-top: 12rpx;
}

/* ===== Spec key/value list (suggested_spec rendered) ===== */
.kv-row {
  display: flex; align-items: flex-start;
  padding: 14rpx 0;
  border-bottom: 1rpx dashed var(--border);
  gap: 16rpx;
}
.kv-row:last-child { border-bottom: none; }
.kv-key {
  width: 160rpx; flex-shrink: 0;
  color: var(--muted); font-size: 24rpx;
}
.kv-val {
  flex: 1; min-width: 0;
  color: var(--text); font-size: 26rpx;
  word-break: break-all;
}

/* ===== Selected card (template option) ===== */
.card-selectable {
  border: 4rpx solid rgba(226, 232, 240, 0.6);
  transition: border-color 0.15s, box-shadow 0.15s;
}
.card-selectable.selected {
  border-color: var(--primary);
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.18);
}

/* ===== Skeleton loading ===== */
.skeleton {
  background: linear-gradient(90deg, #eef2f7 25%, #f8fafc 50%, #eef2f7 75%);
  background-size: 200% 100%;
  animation: skeleton-shimmer 1.4s linear infinite;
  border-radius: 12rpx;
}
.skeleton-line { height: 28rpx; margin: 12rpx 0; }
.skeleton-block { height: 120rpx; margin: 16rpx 0; border-radius: 20rpx; }
@keyframes skeleton-shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ===== Tap targets ===== */
.tap-area { padding: 12rpx 16rpx; border-radius: 12rpx; }
.tap-area:active { background: rgba(37, 99, 235, 0.06); }

/* ===== Banner (offline / warning) ===== */
.banner {
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  display: flex; align-items: center; gap: 12rpx;
}
.banner-warn { background: #fef3c7; color: #92400e; }
.banner-err  { background: #fee2e2; color: #991b1b; }
