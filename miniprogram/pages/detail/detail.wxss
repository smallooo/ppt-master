/* pages/detail/detail.wxss */

.detail-url-input {
	min-height: 96rpx;
	padding-top: 26rpx;
	padding-bottom: 26rpx;
	font-size: 30rpx;
	line-height: 1.2;
}

.outline-editor {
	width: 100%;
	min-height: 420rpx;
	padding: 24rpx;
	box-sizing: border-box;
	border-radius: 24rpx;
	background: #f8fafc;
	border: 2rpx solid #dbe4ee;
	font-size: 28rpx;
	line-height: 1.6;
	color: #1f2937;
}

.brief-toolbar {
	display: flex;
	margin-left: auto;
	gap: 12rpx;
}

.brief-toolbar-btn {
	margin-top: 0;
	padding: 10rpx 20rpx;
}

.brief-card {
	padding: 20rpx 24rpx;
	margin-top: 16rpx;
	border-radius: 20rpx;
	background: #f8fafc;
	border: 2rpx solid #dbe4ee;
}

.brief-card-head {
	align-items: center;
}

.brief-label {
	font-size: 24rpx;
	font-weight: 600;
	color: #64748b;
}

.brief-actions {
	display: flex;
	margin-left: auto;
	gap: 12rpx;
}

.brief-action-btn {
	margin-top: 0;
	padding: 8rpx 18rpx;
	font-size: 22rpx;
}

.brief-action-danger {
	color: #b91c1c;
	border-color: #fecaca;
}

.brief-title-input {
	width: 100%;
	margin-top: 10rpx;
	padding: 0 0 12rpx;
	border-bottom: 2rpx solid #dbe4ee;
	font-size: 30rpx;
	font-weight: 600;
	color: #10253e;
}

.brief-summary-editor {
	width: 100%;
	min-height: 120rpx;
	margin-top: 10rpx;
	padding: 18rpx 20rpx;
	box-sizing: border-box;
	border-radius: 16rpx;
	background: #ffffff;
	border: 2rpx solid #dbe4ee;
	font-size: 26rpx;
	line-height: 1.6;
	color: #334155;
}

.brief-mini-label {
	margin-top: 14rpx;
	font-size: 22rpx;
	color: #64748b;
}

.brief-bullets-editor {
	width: 100%;
	min-height: 180rpx;
	margin-top: 10rpx;
	padding: 18rpx 20rpx;
	box-sizing: border-box;
	border-radius: 16rpx;
	background: #ffffff;
	border: 2rpx solid #dbe4ee;
	font-size: 24rpx;
	line-height: 1.6;
	color: #475569;
}

